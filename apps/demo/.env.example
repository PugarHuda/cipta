# Demo Server — copy ke .env dan isi nilainya
# cp .env.example .env

# Wallet kreator yang menerima USDC/ETH
CREATOR_WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS

# Supabase (opsional — untuk tracking di dashboard)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Port server
PORT=3001

# Network (base atau base-sepolia)
NETWORK=base-sepolia

# Private key untuk ERC-8004 giveFeedback on-chain (opsional)
# Generate: openssl rand -hex 32 → tambah prefix 0x
# SIGNER_KEY=0xYOUR_PRIVATE_KEY_HERE
